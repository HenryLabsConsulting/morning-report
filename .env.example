# Copy to .env and adjust. Defaults work with docker compose, so this is optional.

# Optional. Leave blank to use the committed sample summary text. Set a real key
# for a live Claude-written morning briefing.
ANTHROPIC_API_KEY=

# Email envelope for the report (used by the SMTP delivery step).
REPORT_FROM=reports@morning-report.local
REPORT_TO=owner@tri-county-plumbing.local
